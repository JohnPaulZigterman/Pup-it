{
  "name": "pup-it",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "node --watch server/index.js",
    "dev:qa": "node scripts/dev-qa.mjs",
    "db:migrate": "node server/scripts/migrate.js",
    "start": "node server/index.js",
    "build": "vite build",
    "render:build": "npm run build && npx playwright install --with-deps chromium",
    "preview": "vite preview --host 0.0.0.0",
    "test:qa": "playwright test"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^0.468.0",
    "pg": "^8.20.0",
    "playwright": "^1.59.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
